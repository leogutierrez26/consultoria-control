# Archivo de ejemplo de variables de entorno.
# COPIAR a .env y ajustar los valores. NUNCA incluir secretos reales en el repo.
# En producción estos valores deben suministrarse mediante variables protegidas o un gestor de secretos.

# --- Servidor ---
# Puerto donde escucha la API
API_PORT=4000
# URL pública del frontend (usada en correos/enlaces)
PUBLIC_APP_URL=http://localhost:3000
# Secreto para firmar JWT (CAMBIAR en producción)
JWT_SECRET=cambiar-este-secreto-en-produccion
# Tiempo de expiración del token (segundos)
JWT_EXPIRES_IN=86400
# Máximo de intentos de login fallidos antes de bloquear
MAX_LOGIN_ATTEMPTS=5
# Minutos de bloqueo temporal tras superar intentos
LOGIN_LOCK_MINUTES=15

# --- Base de datos (PostgreSQL) ---
# Usado por el runner de migraciones y por la app
PGHOST=postgres
PGPORT=5432
PGDATABASE=consultoria
PGUSER=consultoria
PGPASSWORD=consultoria
# URL completa usada por Node (pg)
DATABASE_URL=postgres://consultoria:consultoria@postgres:5432/consultoria

# --- Correo (SMTP) ---
# Si SMTP_HOST está vacío, el sistema simula el envío (lo registra, no lo manda).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@consultoriacontrol.app

# --- Almacenamiento de archivos ---
# Ruta dentro del contenedor montada en volumen persistente
UPLOAD_DIR=/uploads
MAX_FILE_MB=20

# --- Fuso horario por defecto ---
DEFAULT_TZ=America/Bogota
